<Window x:Class="PitWall.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PitWall Replay"
        Height="620"
        Width="1080"
        MinHeight="520"
        MinWidth="860">
    <Grid Background="#111318">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="16,14,16,10" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="PitWall Replay"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="Session"
                           Foreground="#AEB4C0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Width="120"
                         Height="30"
                         Text="{Binding SessionKeyText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Load"
                        Width="72"
                        Height="30"
                        Margin="8,0,0,0"
                        Command="{Binding LoadReplayCommand}" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="16,0,16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Margin="0,0,14,0">
                <Button Width="82"
                        Height="32"
                        Content="{Binding PlayPauseText}"
                        Command="{Binding PlayPauseCommand}" />
                <Button Width="72"
                        Height="32"
                        Margin="8,0,0,0"
                        Content="Stop"
                        Command="{Binding StopCommand}" />
            </StackPanel>

            <Slider Grid.Row="0"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="{Binding DurationSeconds}"
                    Value="{Binding CurrentTimeSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    VerticalAlignment="Center" />

            <StackPanel Grid.Row="0"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentTimeText}"
                           Foreground="White"
                           MinWidth="54"
                           TextAlignment="Right" />
                <TextBlock Text=" / "
                           Foreground="#6D7480" />
                <TextBlock Text="{Binding DurationText}"
                           Foreground="#AEB4C0"
                           MinWidth="54" />
                <TextBlock Text="Speed"
                           Foreground="#AEB4C0"
                           Margin="18,0,8,0" />
                <TextBox Width="54"
                         Height="28"
                         Text="{Binding PlaybackSpeed, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="x"
                           Foreground="#AEB4C0"
                           Margin="4,0,0,0" />
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Grid.ColumnSpan="3"
                       Text="{Binding FrameText}"
                       Foreground="#AEB4C0"
                       Margin="0,8,0,0" />
        </Grid>

        <DataGrid Grid.Row="2"
                  Margin="16,0,16,14"
                  ItemsSource="{Binding DriverStates}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  CanUserSortColumns="False"
                  EnableColumnVirtualization="True"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="#151922"
                  Foreground="White"
                  RowBackground="#151922"
                  AlternatingRowBackground="#1B202B"
                  BorderBrush="#2B313D"
                  HorizontalGridLinesBrush="#2B313D">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="56" />
                <DataGridTextColumn Header="No" Binding="{Binding DriverNumber}" Width="56" />
                <DataGridTextColumn Header="Driver" Binding="{Binding DriverName}" Width="90" />
                <DataGridTextColumn Header="Speed" Binding="{Binding Speed}" Width="90" />
                <DataGridTextColumn Header="Gear" Binding="{Binding Gear}" Width="64" />
                <DataGridTextColumn Header="DRS" Binding="{Binding Drs}" Width="120" />
                <DataGridTextColumn Header="Gap" Binding="{Binding Gap}" Width="90" />
                <DataGridTextColumn Header="Interval" Binding="{Binding Interval}" Width="90" />
                <DataGridTextColumn Header="Lap" Binding="{Binding Lap}" Width="64" />
                <DataGridTextColumn Header="X" Binding="{Binding X}" Width="90" />
                <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3"
                   Margin="16,0,16,14"
                   Text="{Binding StatusText}"
                   Foreground="#AEB4C0"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
